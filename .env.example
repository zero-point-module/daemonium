# Daemonium — environment template.
# Copy to .env and fill in. Everything here is a SERVER-ONLY secret unless it is prefixed
# NEXT_PUBLIC_. A missing REQUIRED var fails `npm run build` (validated in app/lib/env.ts).

# --- Required (no in-code default; the app won't run without them) ---
# Speech-to-text: /api/stt (OpenAI directly — the AI gateway doesn't proxy speech).
OPENAI_API_KEY=
# Text-to-speech: /api/tts (ElevenLabs — Ignis's character voices via eleven_flash_v2_5).
ELEVENLABS_API_KEY=
# The agent's model calls — Claude via the Vercel AI Gateway.
AI_GATEWAY_API_KEY=
# Dynamic: JWT auth (JWKS) + server MPC wallets.
DYNAMIC_ENVIRONMENT_ID=
DYNAMIC_API_TOKEN=
# Decrypts the server wallets' MPC key shares — keep consistent across environments.
DAEMON_WALLET_PASSWORD=

# --- Optional (have safe in-code defaults) ---
# Identity layer — Ethereum L1 (ENS + ERC-8004). Default: a public node (rate-limited).
MAINNET_RPC_URL=
# DeFi/value layer — Base mainnet (sends, swaps). Default: a public node (rate-limited).
BASE_RPC_URL=
# KV store for the wallet/handle index (Vercel KV / any Redis). Unset → gitignored .daemon JSON file.
REDIS_URL=
# Set to "false" to disable on-chain L1 subname minting; falls back to a label-only layer.
ENS_ONCHAIN_MINTING=
# Wrapped parent ENS name agents nest under (default: daemonium.eth).
ENS_PARENT_NAME=
# Public base URL so agent-card URIs resolve on deploy (default: http://localhost:3000).
APP_BASE_URL=
# Log verbosity: debug | info | warn | error (default: debug in dev, info in prod).
LOG_LEVEL=
# Pin ONE funded + approved minter across every environment (see app/lib/minter.ts).
# Generate from a store that has a funded minter:
#   npm run minter:export -- path/to/.daemon/wallets.json
MINTER_WALLET=

# --- Account abstraction (ERC-4337) bundlers — for smart-account UserOps ---
# Server-side bundler RPCs. Autonomy (session-key) submits and any SA identity UserOps go here.
# Unset → those paths surface a clear error; the co-sign path uses the NEXT_PUBLIC_ ones below.
# Use a ZeroDev or Pimlico endpoint per chain (free tier is fine for a hackathon).
BUNDLER_RPC_MAINNET=
BUNDLER_RPC_BASE=

# --- Optional, client-exposed (NEXT_PUBLIC_*; fallbacks live in app/providers.tsx) ---
NEXT_PUBLIC_DYNAMIC_ENVIRONMENT_ID=
NEXT_PUBLIC_SEPOLIA_RPC_URL=
# Client-side Base / Ethereum RPCs (wagmi reads + the co-sign public client). Use a getLogs-capable
# provider (e.g. Alchemy) so funding detection works; default is a public node.
NEXT_PUBLIC_BASE_RPC_URL=
NEXT_PUBLIC_MAINNET_RPC_URL=
# Client bundler RPCs for the DEFAULT co-sign path (the user's embedded wallet submits the UserOp).
# Base = value actions; mainnet = identity. Required for co-sign to work in the browser.
NEXT_PUBLIC_BUNDLER_RPC_BASE=
NEXT_PUBLIC_BUNDLER_RPC_MAINNET=

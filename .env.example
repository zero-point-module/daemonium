# Daemonium — environment template.
# Copy to .env and fill in. ALL of these are SERVER-ONLY secrets (workstream B).
# Never expose them to the client. Workstream A (the flame/UI) needs none of them.

# Also powers voice input: /api/stt transcribes the mic with OpenAI
# (the AI gateway does not proxy speech-to-text).
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

ALCHEMY_RPC_URL=

DYNAMIC_ENVIRONMENT_ID=

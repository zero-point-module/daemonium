# Daemonium — environment template.
# Copy to .env and fill in. ALL of these are SERVER-ONLY secrets (workstream B).
# Never expose them to the client. Workstream A (the flame/UI) needs none of them.

# Also powers voice input: /api/stt transcribes the mic with OpenAI
# (the AI gateway does not proxy speech-to-text).
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

ALCHEMY_RPC_URL=

DYNAMIC_ENVIRONMENT_ID=

# Optional — pin ONE funded + approved minter across every environment (each local
# worktree and the deploy), instead of every .daemon store auto-minting its own empty
# one. Base64 of the minter's wallet record, INCLUDING its MPC key shares (keep secret).
# Generate from a store that already holds a funded minter:
#   npm run minter:export -- path/to/.daemon/wallets.json
MINTER_WALLET=
